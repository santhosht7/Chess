@startuml
'Chess UML Diagram
class Game {
    - Board board
    - Player whitePlayer
    - Player blackPlayer
    - List<Move> moves
    - GameStatus gameStatus
    - GameRule gameRule

    + Player getNextPlayer()
    + void makeMove(Player player, Move move)

    + Move getLastMove()
}

Game *--> Board
Game o--> Player
Game --> GameStatus

class GameRule {
    + GameStatus checkGameStatus(Game game)
    + boolean isValidMove(Move move)

    + boolean isDoublePawnJump(Move lastMove, Move CurrentMove)
}

enum GameStatus {
    CHECK
    CHECKMATE
    STALEMATE
    ONGOING
}

class Board {
    - Cell[][] cell
    - List<BoardEntity> boardEntities


    + void initializeBoard()
    + void makeMove(Player player, Move move)
    + Cell getCell(Position position)
    + boolean isValidCell(Position position)
    + void captureBoardEntity(BoardEntity entity)
    + void replaceBoardEntity(BoardEntity fromEntity, BoardEntity toEntity)
}
Board *--> Cell

class Cell {
    - Color color
    - Position position
    - CellState cellState
    - BoardEntity boardEntity
    + void clearCell()
    + CellState getCellState()
}
Cell --> Color
Cell *--> Position

enum CellState {
    EMPTY
    FILLED
}
abstract class BoardEntity {
    - EntityType type
    - Color color
    - Position position
    - boolean isCaptured
    - boolean isMovedBefore
    # {abstract} List<Move> getValidMoves()
    # {abstract} boolean isValidMove(Move move)
    + Position getPosition()
}

BoardEntity --> EntityType
BoardEntity --> Color

enum EntityType {
    PAWN
    ROOK
    KNIGHT
    BISHOP
    QUEEN
    KING
}

enum Color {
    WHITE
    BLACK
}

class Pawn extends BoardEntity {
    + List<Move> getValidMoves()
    + boolean isValidMove(Move move)
}

class Rook extends BoardEntity {
    + List<Move> getValidMoves()
    + boolean isValidMove(Move move)
}

class Bishop extends BoardEntity {
    + List<Move> getValidMoves()
    + boolean isValidMove(Move move)
}

class Knight extends BoardEntity {
    + List<Move> getValidMoves()
    + boolean isValidMove(Move move)
}

class Queen extends BoardEntity {
    + List<Move> getValidMoves()
    + boolean isValidMove(Move move)
}

class King extends BoardEntity {
    + List<Move> getValidMoves()
    + boolean isValidMove(Move move)
}

abstract class Player {
    - String name
    - Color color
    - PlayerType playerType
    - int points

    # Move getMove()
}
Player --> PlayerType
Player --> Color

enum PlayerType {
    BOT
    HUMAN
}

class BotPlayer extends Player {
    - BotDifficultyLevel level
    - BotPlayingStrategy strategy

    + Move getMove()
}

BotPlayer --> BotDifficultyLevel

class HumanPlayer extends Player {
    + Move getMove()
}
abstract class Move {
    - Cell fromCell
    - Cell toCell
    - BoardEntity boardEntity
    - MoveType type
}
enum MoveType {
    PAWN_PROMOTION
    CASTLING
    EN_PASSANT
    STANDARD
}

class PawnPromotion extends Move {
}

class Castling extends Move {
    - Cell rookFromCell
    - Cell rooToCell
    + void performCastling()
}

class EnPassant extends Move {
    + void performEnPassant()
}

class Position {
    - int rank
    - int file
}

enum BotDifficultyLevel {
    EASY
    MEDIUM
    HARD
}

interface BotPlayingStrategy {
    + Move getMove(Player player, Board board)
}

class EasyBotPlayingStrategy implements BotPlayingStrategy {
    + Move getMove(Player player, Board board)
}

class MediumBotPlayingStrategy implements BotPlayingStrategy {
    + Move getMove(Player player,  Board board)
}

class HardBotPlayingStrategy implements BotPlayingStrategy {
    + Move getMove(Player player, Board board)
}

@enduml